{
  "name": "homebridge-roon-complete",
  "version": "1.0.0",
  "description": "Homebridge platform for Roon zones, radio, playlists, and genres",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "deploy": "npm run build && node scripts/deploy.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18",
    "homebridge": "^1.6.0"
  },
  "peerDependencies": {
    "homebridge": "^1.6.0"
  },
  "keywords": [
    "homebridge-plugin",
    "roon",
    "homebridge"
  ],
  "author": "",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "config.schema.json"
  ],
  "dependencies": {
    "node-roon-api": "github:RoonLabs/node-roon-api",
    "node-roon-api-browse": "github:RoonLabs/node-roon-api-browse",
    "node-roon-api-transport": "github:RoonLabs/node-roon-api-transport"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "homebridge": "^1.11.3",
    "typescript": "^5.7.2"
  }
}
