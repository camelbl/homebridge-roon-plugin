{
  "name": "homebridge-roon-control",
  "version": "1.2.1",
  "displayName": "Roon Control",
  "description": "Homebridge plugin for Roon — volume sliders, zone controllers, radio, playlists and genres in HomeKit",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "deploy": "npm run build && node scripts/deploy.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": "^18.20.4 || ^20.15.1 || ^22 || ^24",
    "homebridge": "^1.6.0 || ^2.0.0-beta.0"
  },
  "peerDependencies": {
    "homebridge": "^1.6.0 || ^2.0.0-beta.0"
  },
  "keywords": [
    "homebridge-plugin",
    "roon",
    "homekit",
    "homebridge",
    "roon-api",
    "music",
    "audio",
    "speaker",
    "volume"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/camelbl/homebridge-roon-plugin.git"
  },
  "homepage": "https://github.com/camelbl/homebridge-roon-plugin#readme",
  "bugs": {
    "url": "https://github.com/camelbl/homebridge-roon-plugin/issues"
  },
  "files": [
    "dist",
    "config.schema.json"
  ],
  "dependencies": {
    "node-roon-api": "github:RoonLabs/node-roon-api",
    "node-roon-api-browse": "github:RoonLabs/node-roon-api-browse",
    "node-roon-api-transport": "github:RoonLabs/node-roon-api-transport"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "homebridge": "^2.0.0-beta.79",
    "typescript": "^5.7.2"
  }
}
